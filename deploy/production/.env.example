# FormuMind production — copy to .env and fill secrets (do not commit .env)

# ── PostgreSQL (FormuMind business DB) ───────────────────────────────────────
FORMUMIND_PG_USER=formumind
FORMUMIND_PG_PASSWORD=change-me-strong
FORMUMIND_PG_DB=formumind

# ── Datalab ELN (required — external cluster or compose on formumind-eln net) ─
FORMUMIND_DATALAB_API_URL=http://datalab-api:5001

# ── API auth (recommended in production) ─────────────────────────────────────
FORMUMIND_API_AUTH_ENABLED=true
FORMUMIND_API_TOKEN=change-me-bearer-token
# Baked into frontend build when using compose build args:
VITE_API_TOKEN=change-me-bearer-token

# ── LLM (at least one provider for online features) ──────────────────────────
FORMUMIND_ANTHROPIC_API_KEY=
FORMUMIND_LLM_PROVIDER=anthropic

# ── Optional: external managed Postgres/Redis (override compose services) ────
# FORMUMIND_DB_URL=postgresql+psycopg2://user:pass@rds-host:5432/formumind
# FORMUMIND_REDIS_URL=redis://:password@redis-host:6379/0

# ── Replica counts (docker compose --scale) ──────────────────────────────────
FORMUMIND_BACKEND_REPLICAS=2
FORMUMIND_WORKER_REPLICAS=3
