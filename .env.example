# FormuMind environment configuration. Copy to `.env` and fill as needed.
# Every value is optional — the platform runs fully offline without any of them.

# --- LLM provider selection ---
# Set FORMUMIND_LLM_PROVIDER to one of: anthropic, openai, gemini, xai, groq,
# deepseek, qwen, moonshot, minimax.  When unset (or no key provided) the
# platform falls back to the deterministic rule-based engine.
FORMUMIND_LLM_PROVIDER=anthropic
FORMUMIND_LLM_MODEL=claude-sonnet-4-6

# Anthropic (Claude)
# FORMUMIND_ANTHROPIC_API_KEY=sk-ant-...

# OpenAI (GPT-4o etc.)
# FORMUMIND_OPENAI_API_KEY=sk-...

# Google Gemini
# FORMUMIND_GEMINI_API_KEY=AIza...

# xAI (Grok) — OpenAI-compatible, base https://api.x.ai/v1
# FORMUMIND_XAI_API_KEY=xai-...

# Meta via Groq — OpenAI-compatible, base https://api.groq.com/openai/v1
# FORMUMIND_GROQ_API_KEY=gsk_...

# DeepSeek — OpenAI-compatible, base https://api.deepseek.com
# Latest models: deepseek-v4-pro (flagship) / deepseek-v4-flash (fast & economical).
# Legacy deepseek-chat / deepseek-reasoner retire 2026-07-24.
# FORMUMIND_DEEPSEEK_API_KEY=sk-...

# Qwen / DashScope — OpenAI-compatible, base https://dashscope.aliyuncs.com/compatible-mode/v1
# FORMUMIND_QWEN_API_KEY=sk-...

# Kimi / Moonshot — OpenAI-compatible, base https://api.moonshot.cn/v1
# FORMUMIND_MOONSHOT_API_KEY=sk-...

# MiniMax — OpenAI-compatible, base https://api.minimax.chat/v1
# FORMUMIND_MINIMAX_API_KEY=...

# Custom OpenAI-compatible base URL (overrides provider default)
# FORMUMIND_LLM_BASE_URL=https://my-llm-proxy.example.com/v1

# Datalab Headless ELN (DOE workbench SSOT)
# FORMUMIND_CAMPAIGN_BACKEND=datalab
# FORMUMIND_DATALAB_API_URL=http://localhost:5001
# FORMUMIND_EXPERIMENT_BACKEND=datalab

# --- Celery / Redis ---
# In docker-compose these are set per-service. For local dev leave CELERY_EAGER
# true to run optimization tasks in-process without a broker.
FORMUMIND_REDIS_URL=redis://localhost:6379/0
FORMUMIND_CELERY_EAGER=true

# --- Database ---
# SQLite (default, zero-config). Switch to Postgres for multi-process deployments.
# FORMUMIND_DB_URL=sqlite:///./data/formumind.db
# FORMUMIND_DB_URL=postgresql+psycopg2://user:password@localhost/formumind

# --- Optimization defaults ---
FORMUMIND_OPTIMIZE_ITERATIONS=24
FORMUMIND_TOP_N_FORMULAS=5

# --- v0.4 optional engine settings ---
# RAG retrieval backend: auto (use embeddings if sentence-transformers is installed,
# else TF-IDF), embedding (force semantic), tfidf (force lexical).
# FORMUMIND_RAG_BACKEND=auto

# Set to true to enrich raw-material SMILES/molar-mass from PubChem at startup.
# Requires the `intel` extra and a network connection.
# FORMUMIND_ENRICH_COMPOUNDS=false

# Optional extras to install for v0.4/v0.5 features:
#   pip install -e ".[embedding]"   — sentence-transformers semantic RAG
#   pip install -e ".[bo]"          — BoTorch GP optimizer (requires torch)
#   pip install -e ".[color]"       — colour-science CIELAB / CIEDE2000
#   pip install -e ".[optimize]"    — Optuna NSGA-II (CPU multi-objective)
#   pip install -e ".[intel]"       — paper-qa, ChemCrow, PubChemPy, arXiv, S2, DDG
#   pip install -e ".[science]"     — thermo, RDKit, ChemFormula, scikit-learn

# --- v0.7 NotebookLM retrieval source (optional) ---
# Use a Google NotebookLM notebook as a search source. Setup:
#   pip install -e ".[notebooklm]"   — installs notebooklm-py + Playwright/Chromium
#   notebooklm login                 — one-time browser sign-in, writes session file
# Unofficial Google API; left disabled by default. When off / not logged in,
# selecting the NotebookLM source simply returns no results.
# FORMUMIND_NOTEBOOKLM_ENABLED=false
# FORMUMIND_NOTEBOOKLM_NOTEBOOK_ID=your-notebook-id
# FORMUMIND_NOTEBOOKLM_STORAGE_PATH=./data/notebooklm_auth.json

# --- v0.8 multi-agent event bus (optional, reserved) ---
# Redis Pub/Sub for agent lifecycle events and next-phase physics-job handoff.
# Disabled by default: agents.bus.publish() is a silent no-op until enabled and
# a reachable Redis is configured (reuses FORMUMIND_REDIS_URL above).
# FORMUMIND_AGENT_BUS_ENABLED=false

# --- v1.0 检索增强 API（SerpAPI / Tavily）---
# SerpAPI — Google Scholar / Patents 优先链（https://serpapi.com/）
# FORMUMIND_SERPAPI_API_KEY=...
# Tavily — 学术与网页语义检索（https://tavily.com/）
# FORMUMIND_TAVILY_API_KEY=tvly-...
# FORMUMIND_ARXIV_SEARCH_ENABLED=true
# FORMUMIND_ARXIV_DOMAIN_FILTER=true
# FORMUMIND_OPENALEX_ENABLED=true

# --- v1.0 深度研究外部知识库（Phase 2+，Phase 1 仅预留配置）---
# OpenAlex 礼貌池（推荐填写联系邮箱以进入礼貌池）
# FORMUMIND_OPENALEX_MAILTO=researcher@example.com
# EPO OPS API（https://developers.epo.org/）
# FORMUMIND_EPO_CONSUMER_KEY=...
# FORMUMIND_EPO_CONSUMER_SECRET=...
# USPTO Open Data API
# FORMUMIND_USPTO_API_KEY=...

# --- v0.5 LAMMPS / HTPolyNet MD simulation (P7, optional) ---
# Activate: docker compose --profile heavy up lammps
# Then set the path to the LAMMPS binary inside the container:
# LAMMPS_EXEC=/usr/bin/lmp

# --- v0.7 pyDOE + BayBE dual-engine (optional) ---
# Cold-start DOE:  pip install -e ".[pydoe]"
# Active learning: pip install -e ".[bo,baybe,science,pydoe]"
# API: POST /api/doe?engine=pydoe  |  POST /api/doe/active?engine=baybe  |  POST /api/optimize engine=baybe
